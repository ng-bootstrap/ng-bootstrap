{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"outDir": "../out-tsc/test-app",
		"paths": {
			"@ng-bootstrap/ng-bootstrap": ["../src"],
			"@ng-bootstrap/ng-bootstrap/*": ["../src/*/public-api"]
		}
	},
	"files": ["src/main.ts"],
	"include": ["src/**/*.d.ts"],
	"angularCompilerOptions": {
		"extendedDiagnostics": {
			"checks": {
				"nullishCoalescingNotNullable": "suppress",
				"optionalChainNotNullable": "suppress"
			}
		}
	}
}
